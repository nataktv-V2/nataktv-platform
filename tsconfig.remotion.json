{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "apps/web",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["apps/web/src/remotion/**/*"]
}
