<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — dark, matching nataktv.com -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#0A0A0C</item>
        <item name="colorPrimaryDark">#0A0A0C</item>
        <item name="colorAccent">#F97316</item>
        <item name="android:windowBackground">#0A0A0C</item>
        <item name="android:navigationBarColor">#0A0A0C</item>
        <item name="android:statusBarColor">#0A0A0C</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>
